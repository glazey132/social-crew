# Revenue Crew Environment Template
# Copy this file to .env and fill in your values
# NEVER commit .env to git - it's in .gitignore

# ====== LLM Configuration ======
# Ollama model identifier (install Ollama first: https://ollama.com)
LLM_MODEL=ollama/qwen3.5:35b-a3b

# Ollama server URL
LLM_BASE_URL=http://localhost:11434

# ====== Workspace Configuration ======
# Your project workspace directory (defaults to project root)
WORKSPACE_DIR=/Users/alexglaze/revenue_crew

# Output directory for final rendered clips (uploaded to TikTok/Shorts)
OUTPUT_DIR=${WORKSPACE_DIR}/outputs

# Source video downloads (raw mp4s pulled from YouTube; kept for re-clipping)
DOWNLOADS_DIR=${WORKSPACE_DIR}/downloads

# State database location
STATE_DB_PATH=${WORKSPACE_DIR}/pipeline_state.db

# ====== Telegram Bot Configuration ======
# 1. Open Telegram and search for @BotFather
# 2. Send /newbot and follow instructions
# 3. Copy the token you receive here
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# 4. To get your chat_id: 
#    - Start a chat with your bot
#    - Send /start
#    - Visit: https://api.telegram.org/bot<YOUR_BOT_TOKEN>/getUpdates
#    - Look for "chat":{"id":123456789} in the response
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ====== Pipeline Limits ======
# Maximum number of clips to generate per run
DAILY_CLIP_LIMIT=3

# Maximum number of candidate videos to evaluate per run
MAX_CANDIDATES=5

# ====== Safety & Testing ======
# Set to true to test flow without actual video processing
# Useful during development
DRY_RUN=false

# Optional: force a single YouTube URL for discovery (watch?v= or youtu.be link).
# Candidate id becomes source_<11-char-id> for dedupe. Clear processed_sources or use a fresh STATE_DB_PATH to re-run.
# SINGLE_TEST_VIDEO_URL=https://www.youtube.com/watch?v=EvIBrUDnh8s

# ====== Video downloading ======
# Default backend is pytubefix (no cookies / PO Token plumbing required).
# Set to "ytdlp" only if you want the legacy yt-dlp + bgutil PO Token path.
# DOWNLOAD_BACKEND=pytubefix

# Maximum source resolution to download (cap). TikTok/Shorts/Reels all serve 1080p,
# so 1080 is the right ceiling — 4K just wastes disk and ffmpeg encode time.
# MAX_DOWNLOAD_RESOLUTION=1080

# ====== Legacy yt-dlp options (only used when DOWNLOAD_BACKEND=ytdlp) ======
# Netscape cookies.txt path (relative to WORKSPACE_DIR or absolute).
# YTDLP_COOKIES_FILE=cookies.txt
# Or browser cookies (may fail on macOS without Full Disk Access for Safari):
# YTDLP_COOKIES_FROM_BROWSER=safari
# YTDLP_COOKIES_FROM_BROWSER=chrome:Default
# YTDLP_FORMAT=18/best[ext=mp4]/best
# YTDLP_FORCE_IPV4=false
# YTDLP_PLAYER_CLIENT=web,tv,android  # used by bgutil-ytdlp-pot-provider plugin
